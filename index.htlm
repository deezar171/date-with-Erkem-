<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Invitation</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #ffd6e8;
  overflow: hidden;
  text-align: center;
  color: white;
}

/* Заголовок */
h1 {
  margin-top: 80px;
  font-size: 32px;
  animation: fade 2s ease-in;
}

/* элементы выбора */
select, input {
  margin-top: 15px;
  padding: 10px;
  border-radius: 12px;
  border: none;
  font-size: 16px;
  outline: none;
}

/* кнопка */
button {
  margin-top: 20px;
  padding: 12px 25px;
  border-radius: 15px;
  border: none;
  background: white;
  color: #ff69b4;
  font-size: 18px;
  font-weight: bold;
  cursor: pointer;
  transition: 0.2s;
}

button:hover {
  transform: scale(1.05);
}

/* плавное появление */
@keyframes fade {
  from {opacity: 0;}
  to {opacity: 1;}
}

/* сердечки */
.heart {
  position: absolute;
  color: white;
  font-size: 18px;
  animation: float 6s linear infinite;
}

@keyframes float {
  0% {transform: translateY(100vh); opacity: 0;}
  20% {opacity: 1;}
  100% {transform: translateY(-10vh); opacity: 0;}
}

/* блоки */
label {
  display: block;
  margin-top: 20px;
  font-size: 16px;
}
</style>
</head>

<body>

<h1>Ты пойдёшь со мной на свидание? 💗</h1>

<!-- ДАТЫ -->
<select>
  <option>26</option>
  <option>27</option>
  <option>28</option>
</select>

<!-- ВРЕМЯ -->
<label>Выбери время (13:00 – 22:00)</label>

<input type="time" min="13:00" max="22:00" value="18:00">

<!-- КНОПКА -->
<button onclick="alert('Я жду тебя ❤️')">Да ❤️</button>

<!-- МУЗЫКА -->
<audio autoplay loop>
  <source src="brent.mp3" type="audio/mpeg">
</audio>

<script>
// белые сердечки
setInterval(() => {
  const heart = document.createElement("div");
  heart.className = "heart";
  heart.innerHTML = "🤍";
  heart.style.left = Math.random() * 100 + "vw";
  document.body.appendChild(heart);

  setTimeout(() => heart.remove(), 6000);
}, 350);
</script>

</body>
</html>
